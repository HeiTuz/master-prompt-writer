{
  "name": "master-prompt-writer",
  "version": "2.5.0",
  "description": "Runtime-agnostic prompt-writing agent skill installer.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "master-prompt-writer": "scripts/install.mjs",
    "master-prompt-writer-install": "scripts/install.mjs"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "SKILL.md",
    "examples/**",
    "references/**",
    "scripts/**"
  ],
  "scripts": {
    "lint": "python3 scripts/lint.py",
    "test": "python3 scripts/test_compile_garden_recipe.py && node scripts/check_prompt.mjs --test",
    "smoke:install": "node scripts/install.mjs --dest /tmp/master-prompt-writer-install-smoke --force --quiet",
    "smoke:runtime": "node scripts/smoke_runtime_installs.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
