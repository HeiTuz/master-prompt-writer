{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.gajae.local/prompt-contracts/production-adapter-options/v1",
  "title": "Production adapter options v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "job_id", "output_path", "ar", "size", "quality", "output_format", "garden_recipe_id", "garden_recipe_sha256", "prompt_bundle_id", "prompt_bundle_sha256", "qc_applicability"],
  "properties": {
    "schema_version": {"const": "production-adapter-options/v1"},
    "job_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "output_path": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*\\.png$", "maxLength": 500},
    "ar": {"type": "string", "enum": ["1:1", "3:4", "4:3", "9:16", "16:9"]},
    "size": {"type": "string", "enum": ["1024x1024", "1536x1024", "1024x1536"]},
    "quality": {"type": "string", "enum": ["low", "medium", "high"]},
    "output_format": {"const": "png"},
    "garden_recipe_id": {"type": "string", "pattern": "^gr_[A-Za-z0-9_-]{8,128}$"},
    "garden_recipe_sha256": {"$ref": "#/$defs/sha256"},
    "prompt_bundle_id": {"type": "string", "pattern": "^pb_[A-Za-z0-9_-]{8,128}$"},
    "prompt_bundle_sha256": {"$ref": "#/$defs/sha256"},
    "qc_applicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promotional", "rendered_text_expected", "evidence_reference_ids", "classification_source"],
      "properties": {
        "promotional": {"type": "boolean"},
        "rendered_text_expected": {"type": "boolean"},
        "evidence_reference_ids": {"type": "array", "maxItems": 4, "items": {"$ref": "#/$defs/referenceId"}},
        "classification_source": {"type": "string", "enum": ["user_intake", "garden_recipe"]}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "referenceId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"}
  }
}
