{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.gajae.local/prompt-contracts/source-evidence-index/v1",
  "title": "Source evidence index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "references"],
  "properties": {
    "schema_version": {"const": "source-evidence-index/v1"},
    "references": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reference_id", "reference_hash"],
        "properties": {
          "reference_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"},
          "reference_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    }
  }
}
